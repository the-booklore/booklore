name: PR Preview - Build Multi-Arch Image

on:
  pull_request:
    types: [opened, synchronize, reopened]

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  build-pr-multiarch:
    name: Build Multi-Arch Image (ARM64 + AMD64)
    runs-on: ubuntu-latest
    permissions:
      contents: read

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Set up QEMU
        uses: docker/setup-qemu-action@v3

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Build Docker Image (Multi-Arch)
        timeout-minutes: 60
        uses: docker/build-push-action@v5
        with:
          context: .
          file: ./testing/Dockerfile
          push: false
          platforms: linux/arm64,linux/amd64
          tags: |
            booklore:pr-${{ github.event.number }}-arm64
            booklore:pr-${{ github.event.number }}-amd64
          cache-from: |
            type=gha
            type=registry,ref=ghcr.io/${{ github.repository }}:buildcache
          cache-to: type=gha,mode=max
          build-args: |
            BUILDKIT_INLINE_CACHE=1
